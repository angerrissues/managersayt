// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdvertiserLead {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  email       String
  phone       String
  brandName   String   @map("brand_name")
  status      String   @default("NEW")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("advertiser_leads")
}

model BloggerLead {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  email       String
  phone       String
  socialLinks String   @map("social_links")
  status      String   @default("NEW")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("blogger_leads")
}

model Blogger {
  id         String   @id
  name       String
  avatarPath String   @map("avatar_path")
  geo        String
  rknStatus  Boolean  @map("rkn_status")
  contact    String
  socials    Json
  details    Json
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("bloggers")
}

model Case {
  id          String   @id
  brand       String
  lineup      String
  agency      String
  description String
  platforms   String[]
  bloggers    String[]
  coverImage  String?  @map("cover_image")
  videos      String[]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("cases")
}
